# Copia este archivo a `.env` y rellena tus claves reales.
# El archivo `.env` está en .gitignore: NUNCA se sube al repositorio.

# --- Binance Futuros USD-M (TESTNET: https://testnet.binancefuture.com) ---
# Solo para el modo en vivo (--live / paper trading). NO hace falta para los
# backtests. Cuando pases a claves reales: con permiso de trade, SIN retiro.
BINANCE_API_KEY=tu_api_key_de_testnet_futuros
BINANCE_API_SECRET=tu_api_secret_de_testnet_futuros
BINANCE_TESTNET=true

# --- Anthropic / Claude Haiku (análisis de sentimiento) ---
# https://console.anthropic.com -> API Keys. Es el UNICO componente de pago,
# pero por diseno cuesta centimos/dia (solo los titulares escalados llaman a Claude).
ANTHROPIC_API_KEY=sk-ant-...

# --- CryptoPanic (noticias cripto historicas, free tier) ---
# https://cryptopanic.com/developers/api/ -> crea cuenta -> copia el auth_token.
CRYPTOPANIC_TOKEN=tu_token_de_cryptopanic
