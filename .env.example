# Copia este archivo a `.env` y rellena tus claves reales.
# El archivo `.env` está en .gitignore: NUNCA se sube al repositorio.
#
# Proyecto actual (post-pivote 2026-07-11): bot cuantitativo S&P 500, solo
# investigación/backtest. No hay broker conectado ni claves de cripto/noticias
# vigentes (ver CLAUDE.md — el híbrido cripto anterior fue borrado del repo).

# --- Financial Modeling Prep (verificación de datos de pago, 2026-07-25) ---
# https://site.financialmodelingprep.com -> crear cuenta gratis -> copiar API key.
# Tier gratis: 250 llamadas/día, $0. Se usa SOLO para verificar si los
# fundamentales/earnings-surprise de FMP son point-in-time de verdad (fecha de
# PUBLICACIÓN del reporte, no solo fin de periodo) antes de considerar pagar
# cualquier proveedor — ver docs/research/ para el protocolo de verificación.
FMP_API_KEY=tu_api_key_gratis_de_fmp

# --- Broker (cuando exista paper trading real) ---
# NO hace falta hoy: todo el desarrollo actual es investigación/backtest.
# Cuando se conecte un broker: paper trading primero, siempre.
BROKER_API_KEY=
BROKER_API_SECRET=
