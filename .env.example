# Copia este archivo a `.env` y rellena tus claves reales.
# El archivo `.env` está en .gitignore: NUNCA se sube al repositorio.

# --- Binance (empezamos en TESTNET: https://testnet.binance.vision) ---
# IMPORTANTE: cuando pases a claves reales, créalas con permiso de trade
# pero SIN permiso de retiro (withdrawal).
BINANCE_API_KEY=tu_api_key_de_testnet
BINANCE_API_SECRET=tu_api_secret_de_testnet
BINANCE_TESTNET=true

# --- Anthropic (análisis de sentimiento con Claude Haiku) ---
ANTHROPIC_API_KEY=sk-ant-...
